  { "src_hex": "a5b2a1bca5e0a5dca1bca5a4a4cea5dda5b1a5e2a5f3a4cea1a1a5aba1bca5c8a5eaa5c3a5b8a4aca4a2a4eaa4dea4bba4f3a1a30aa3b6a3b4a3c7a3c2a5d1a5c3a5afa4cba1a1a5dda5b1a5e2a5f3a4cea1a1a5aba1bca5c8a5eaa5c3a5b8a4f20aa5bba5c3a5c8a4b7a4caa4a4a4c8a1a1a4c4a4aba4a8a4caa4a4a4ada4cea4a6a4aca1a1a4a2a4eaa4dea4b9a1a3", "src_jp": "ゲームボーイのポケモンの　カートリッジがありません。\\n６４ＧＢパックに　ポケモンの　カートリッジを\\nセットしないと　つかえないきのうが　あります。", "target": "No Game Boy game inserted.\nInsert one in the N64 Transfer\nPak to use all features." },
  { "src_hex": "a5dda5b1a5e2a5f3a4ce20a5aba1bca5c8a5eaa5c3a5b8a4ac20a5bba5c3a5c80aa4b5a4eca4c6a4a4a4dea4bba4f3a1a320a4a2a4caa4bfa4cea5dda5b1a5e2a5f3a4f20aa4b5a4f3a4aba4b5a4bba4eba4cba4cf20a4c7a4f3a4b2a4f3a4f2a4ada4c3a4c6a4aba4e90aa5aba1bca5c8a5eaa5c3a5b8a4f220a5bba5c3a5c8a4b7a4c6a4afa4c0a4b5a4a4a1a3", "src_jp": "ポケモンの カートリッジが セット\\nされていません。 あなたのポケモンを\\nさんかさせるには でんげんをきってから\\nカートリッジを セットしてください。", "target": "No Pokemon game inserted.\nTo use your own Pokemon, turn off\nthe power, then insert a game\ninto the N64 Transfer Pak." },
  { "src_hex": "a1d6a4c8a4a6a4eda4afa1d7a4b7a4c6a4a2a4eba1a1a5dda5b1a5e2a5f3a4e40aa4c8a4e2a4c0a4c1a4c8a4cea1a1a4bfa4a4a4bba4f3a4aca1a1a4c7a4ada4eba1a3", "src_jp": "「とうろく」してある　ポケモンや\\nともだちとの　たいせんが　できる。", "target": "Battle with registered\nPokemon, or your friends." },
  { "src_hex": "a5b3a5f3a5d4a5e5a1bca5bfa4e4a1a1a4c8a4e2a4c0a4c1a4c8a1a1a4bfa4a4a4bba4f30aa4b9a4eba1a3", "src_jp": "コンピュータや　ともだちと　たいせん\\nする。", "target": "Battle the computer\nor your friends." },
