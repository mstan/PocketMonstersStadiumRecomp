  { "src_hex": "a4b5a4a4a4ada4e7a4a6a4cea1a1a5c8a5eca1bca5caa1bca4f2a1a1a4ada4e1a4eba1a30aa3b2a4c4a4cea1a1a5eba1bca5eba4cea1a1a4bfa4a4a4aba4a4a4aca1a1a4a2a4eba1a3", "src_jp": "さいきょうの　トレーナーを　きめる。\\n２つの　ルールの　たいかいが　ある。", "target": "Crown the strongest trainer\nusing one of two rule sets." },
